# ----- Postgres connection -----
# In production, point these at your managed Postgres (e.g. RDS / Neon / Supabase Postgres / Railway).
# The same code path is used locally and in production — only these values change.
DB_USER=postgres
DB_PASSWORD=change_me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=campuscloud

# ----- Server -----
PORT=5000
# NODE_ENV=production    # uncomment in prod; enables `secure` cookies for refresh tokens

# ----- JWT secrets -----
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Use the SAME value for both unless you intentionally want separate signing keys.
JWT_SECRET=replace_with_64_hex_chars
JWT_ACCESS_SECRET=replace_with_64_hex_chars
